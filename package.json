{
  "name": "classcast-backend",
  "version": "1.0.0",
  "description": "Production-ready live teaching platform backend",
  "main": "src/gateway/server.js",
  "scripts": {
    "dev": "./scripts/dev.sh",
    "dev:auth": "nodemon src/services/auth/server.js",
    "dev:class": "nodemon src/services/class/server.js",
    "dev:payment": "nodemon src/services/payment/server.js",
    "dev:video": "nodemon src/services/video/server.js",
    "dev:chat": "nodemon src/services/chat/server.js",
    "dev:notification": "nodemon src/services/notification/server.js",
    "dev:media": "nodemon src/services/media/server.js",
    "dev:signaling": "nodemon src/services/signaling/server.js",
    "dev:recording": "nodemon src/services/recording/server.js",
    "dev:gateway": "nodemon src/gateway/server.js",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:build": "docker build -t classcast-backend .",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "seed": "node scripts/seed.js"
  },
  "keywords": [
    "edtech",
    "live-streaming",
    "webrtc",
    "microservices"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "amqplib": "^0.10.3",
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "bull": "^4.11.5",
    "compression": "^1.7.4",
    "connect-redis": "^7.1.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.17.3",
    "express-validator": "^7.0.1",
    "fluent-ffmpeg": "^2.1.2",
    "handlebars": "^4.7.8",
    "helmet": "^7.1.0",
    "http-proxy-middleware": "^2.0.6",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "mediasoup": "^3.12.17",
    "minio": "^7.1.1",
    "mongoose": "^8.0.0",
    "multer": "^1.4.5-lts.1",
    "multer-s3": "^3.0.1",
    "nodemailer": "^6.9.7",
    "puppeteer": "^21.6.1",
    "socket.io": "^4.5.4",
    "socket.io-client": "^4.5.4",
    "stripe": "^14.25.0",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-node": "^11.1.0",
    "faker": "^5.5.3",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "prettier": "^3.1.1",
    "supertest": "^6.3.3"
  }
}
