<!DOCTYPE html>
<html>
<head>
  <style>
    body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; }
    .container { max-width: 600px; margin: 0 auto; padding: 20px; }
    .header { background: #F59E0B; color: white; padding: 20px; text-align: center; border-radius: 8px 8px 0 0; }
    .content { padding: 20px; background: #f9fafb; border-radius: 0 0 8px 8px; }
    .time { font-size: 20px; font-weight: bold; color: #F59E0B; margin: 10px 0; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>⏰ Reminder</h1>
    </div>
    <div class="content">
      <p>Hi {{name}},</p>
      <p><strong>{{lectureTitle}}</strong> is starting soon!</p>
      <div class="time">{{startTime}}</div>
      <a href="{{joinUrl}}" class="button">Join Lecture</a>
      <p>Don't be late!<br>The ClassCast Team</p>
    </div>
  </div>
</body>
</html>